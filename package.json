{
  "name": "movie-recommend-tool",
  "version": "1.0.0",
  "private": true,
  "description": "Umbrify — intelligent movie recommendations shaped by your taste",
  "author": "Matteo Niessner",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "tw:build": "tailwindcss -i ./src/index.css -o ./public/tailwind.css --minify",
    "tw:watch": "tailwindcss -i ./src/index.css -o ./public/tailwind.css --watch",
    "dev": "npm-run-all -p tw:watch dev:vite",
    "dev:vite": "vite --open",
    "build": "npm run tw:build && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,jsx}\" --max-warnings=0",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json,md}\""
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "axios": "^1.10.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.372.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.16",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "daisyui": "^5.0.43",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "prettier": "^3.3.2",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.19"
  },
  "browserslist": [
    "edge >= 109",
    "firefox >= 115",
    "chrome >= 113",
    "safari >= 16",
    "ios_saf >= 16",
    "opera >= 101"
  ],
  "engines": {
    "node": ">=18.18.0",
    "npm": ">=9.6.0"
  }
}
